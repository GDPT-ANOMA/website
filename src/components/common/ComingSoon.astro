---
import type { Translations } from "../../i18n/translations";

interface Props {
  t: Translations;
  pageName: string;
  homeHref?: string;
}

const { t, pageName, homeHref = "/" } = Astro.props;
---

<main class="px-6 lg:px-20 py-24 min-h-[55vh] flex items-center">
  <section class="max-w-3xl mx-auto w-full bg-white/80 backdrop-blur rounded-3xl border border-primary/10 shadow-xl p-10 lg:p-14 text-center">
    <p class="text-xs uppercase tracking-[0.2em] font-bold text-primary/70 mb-4">GDPT Anoma</p>
    <h1 class="text-4xl lg:text-5xl font-display font-bold text-slate-900 mb-6">
      {t.placeholder.titlePrefix} {pageName}
    </h1>
    <p class="text-slate-700 mb-10 text-lg leading-relaxed">{t.placeholder.body}</p>
    <a href={homeHref} class="inline-flex items-center justify-center rounded-xl bg-primary text-white px-8 py-3 font-bold hover:opacity-90 transition-opacity">
      {t.placeholder.backHome}
    </a>
  </section>
</main>
